{
	"name": "@wolf-tui/solid",
	"version": "1.2.1",
	"description": "SolidJS adapter for Wolfie",
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./build/index.d.ts",
			"default": "./build/index.js"
		},
		"./renderer": {
			"types": "./build/renderer/index.d.ts",
			"default": "./build/renderer/index.js"
		},
		"./styles": {
			"types": "./build/styles/index.d.ts",
			"default": "./build/styles/index.js"
		}
	},
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "vite build --watch",
		"build": "vite build",
		"prepare": "npm run build",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"files": [
		"build"
	],
	"dependencies": {
		"@wolf-tui/core": "workspace:*",
		"@wolf-tui/shared": "workspace:*",
		"ansi-escapes": "^7.2.0",
		"ansi-styles": "^6.2.1",
		"auto-bind": "^5.0.1",
		"cli-boxes": "^3.0.0",
		"cli-cursor": "^4.0.0",
		"cli-spinners": "^3.4.0",
		"figures": "^6.1.0",
		"cli-truncate": "^5.1.1",
		"code-excerpt": "^4.0.0",
		"es-toolkit": "^1.39.10",
		"indent-string": "^5.0.0",
		"is-in-ci": "^2.0.0",
		"patch-console": "^2.0.0",
		"signal-exit": "^3.0.7",
		"stack-utils": "^2.0.6",
		"type-fest": "^4.27.0",
		"wrap-ansi": "^9.0.0"
	},
	"devDependencies": {
		"@wolf-tui/css-parser": "workspace:*",
		"@wolf-tui/plugin": "workspace:*",
		"@wolf-tui/spec": "workspace:*",
		"memfs": "^4.56.10",
		"vite-plugin-solid": "^2.11.0",
		"solid-js": "^1.9.0"
	},
	"peerDependencies": {
		"chalk": "^5.0.0",
		"solid-js": "^1.9.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OneEyed1366/wolfi-tui.git",
		"directory": "packages/solid"
	},
	"homepage": "https://github.com/OneEyed1366/wolfi-tui/tree/master/packages/solid#readme",
	"bugs": {
		"url": "https://github.com/OneEyed1366/wolfi-tui/issues"
	},
	"author": "A.Prokopenko <psevdoproger@gmail.com>"
}
