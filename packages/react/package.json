{
	"name": "@wolf-tui/react",
	"version": "1.2.1",
	"description": "React adapter for Wolfie",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OneEyed1366/wolfi-tui.git",
		"directory": "packages/react"
	},
	"author": "A.Prokopenko <psevdoproger@gmail.com>",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./build/index.d.ts",
			"default": "./build/index.js"
		},
		"./styles": {
			"types": "./build/styles/index.d.ts",
			"default": "./build/styles/index.js"
		}
	},
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "vite build --watch",
		"build": "vite build",
		"prepare": "npm run build",
		"test": "vitest run",
		"test:watch": "vitest",
		"example": "pnpm --filter styling-super-hybrid example"
	},
	"files": [
		"build"
	],
	"keywords": [
		"react",
		"cli",
		"jsx",
		"stdout",
		"components",
		"command-line",
		"preact",
		"redux",
		"print",
		"render",
		"colors",
		"text"
	],
	"dependencies": {
		"@wolf-tui/core": "workspace:*",
		"@wolf-tui/shared": "workspace:*",
		"ansi-escapes": "^7.2.0",
		"ansi-styles": "^6.2.1",
		"auto-bind": "^5.0.1",
		"cli-boxes": "^3.0.0",
		"cli-cursor": "^4.0.0",
		"cli-spinners": "^3.4.0",
		"cli-truncate": "^5.1.1",
		"code-excerpt": "^4.0.0",
		"deepmerge": "^4.3.1",
		"es-toolkit": "^1.39.10",
		"figures": "^6.1.0",
		"indent-string": "^5.0.0",
		"is-in-ci": "^2.0.0",
		"patch-console": "^2.0.0",
		"signal-exit": "^3.0.7",
		"stack-utils": "^2.0.6",
		"type-fest": "^4.27.0",
		"wrap-ansi": "^9.0.0"
	},
	"devDependencies": {
		"@wolf-tui/css-parser": "workspace:*",
		"@wolf-tui/plugin": "workspace:*",
		"@wolf-tui/spec": "workspace:*",
		"memfs": "^4.56.10",
		"ts-loader": "^9.5.4"
	},
	"peerDependencies": {
		"@types/react": ">=19.0.0",
		"chalk": "^5.0.0",
		"react": ">=19.0.0",
		"react-devtools-core": "^7.0.0",
		"react-reconciler": "^0.33.0"
	},
	"peerDependenciesMeta": {
		"@types/react": {
			"optional": true
		},
		"react-devtools-core": {
			"optional": true
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://github.com/OneEyed1366/wolfi-tui/tree/master/packages/react#readme",
	"bugs": {
		"url": "https://github.com/OneEyed1366/wolfi-tui/issues"
	}
}
