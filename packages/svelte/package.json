{
	"name": "@wolf-tui/svelte",
	"version": "1.0.1",
	"description": "Svelte 5 adapter for Wolfie",
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./build/index.d.ts",
			"default": "./build/index.js"
		},
		"./styles": {
			"types": "./build/styles/index.d.ts",
			"default": "./build/styles/index.js"
		}
	},
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "vite build --watch",
		"build": "vite build && node scripts/postbuild.cjs",
		"prepare": "npm run build"
	},
	"files": [
		"build"
	],
	"dependencies": {
		"@wolf-tui/core": "workspace:*",
		"@wolf-tui/shared": "workspace:*",
		"chalk": "^5.0.0",
		"ansi-escapes": "^7.2.0",
		"ansi-styles": "^6.2.1",
		"auto-bind": "^5.0.1",
		"cli-boxes": "^3.0.0",
		"cli-cursor": "^4.0.0",
		"clsx": "^2.1.1",
		"cli-spinners": "^3.4.0",
		"figures": "^6.1.0",
		"cli-truncate": "^5.1.1",
		"code-excerpt": "^4.0.0",
		"es-toolkit": "^1.39.10",
		"esm-env": "^1.2.2",
		"indent-string": "^5.0.0",
		"is-in-ci": "^2.0.0",
		"patch-console": "^2.0.0",
		"signal-exit": "^3.0.7",
		"stack-utils": "^2.0.6",
		"type-fest": "^4.27.0",
		"wrap-ansi": "^9.0.0"
	},
	"devDependencies": {
		"@wolf-tui/css-parser": "workspace:*",
		"@wolf-tui/plugin": "workspace:*",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"svelte": "^5.0.0",
		"vite-plugin-dts": "^4.5.0"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OneEyed1366/wolf-tui.git",
		"directory": "packages/svelte"
	},
	"homepage": "https://github.com/OneEyed1366/wolf-tui/tree/master/packages/svelte#readme",
	"bugs": {
		"url": "https://github.com/OneEyed1366/wolf-tui/issues"
	},
	"author": "A.Prokopenko <psevdoproger@gmail.com>"
}
