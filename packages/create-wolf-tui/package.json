		"unbuild": "^3.5.0",
		"vitest": "^3.1.1"
	},
	"engines": {
		"node": ">=20"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OneEyed1366/wolf-tui.git",
		"directory": "packages/create-wolf-tui"
	},
