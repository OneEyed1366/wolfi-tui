{
	"name": "create-wolf-tui",
	"version": "0.1.0",
	"description": "Scaffold wolf-tui terminal UI projects",
	"license": "MIT",
	"type": "module",
	"bin": {
		"create-wolf-tui": "./dist/bin/index.mjs"
	},
	"main": "./dist/index.mjs",
